<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>named_entity_recognition</name>
    <description>Extract named entities (people, organizations, locations, dates, etc.) from unstructured text using Ollama LLM</description>
    <extended_description>This transformation demonstrates Named Entity Recognition (NER) using a local LLM.

Key Features:
- Extracts multiple entity types: PERSON, ORGANIZATION, LOCATION, DATE, PRODUCT, etc.
- Returns structured JSON with entity text, type, and context
- Handles diverse document types: emails, reports, contracts, etc.
- Educational version with detailed prompts for learning

Use Case: Document processing, customer data extraction, log analysis</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434/api/generate</default_value>
        <description>Ollama API endpoint</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>LLM model to use for NER</description>
      </parameter>
    </parameters>
    <log>
