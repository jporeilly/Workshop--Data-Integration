        <default_value>15m</default_value>
        <description>Keep model loaded in memory (5m/15m/30m/60m)</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>LLM model to use for NER</description>
      </parameter>
      <parameter>
