<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>text_summarization</name>
    <description>Summarize documents using Ollama LLM with structured output</description>
    <extended_description>This transformation demonstrates Text Summarization using a local LLM.

Key Features:
- Generates concise 2-3 sentence summaries
- Extracts bullet points, key takeaways, and action items
- Returns structured JSON output
- Handles diverse document types: meetings, reports, emails, etc.
- Educational version with detailed prompts for learning

Use Case: Document processing, meeting notes summarization, content digestion</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434</default_value>
        <description>Ollama API base URL</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>LLM model to use for summarization</description>
      </parameter>
    </parameters>
    <log>
      <trans-log-table>
        <connection/>
        <schema/>
        <table/>
        <size_limit_lines/>
        <interval/>
        <timeout_days/>
        <field>
          <id>ID_BATCH</id>
          <enabled>Y</enabled>
          <name>ID_BATCH</name>
        </field>
      </trans-log-table>
    </log>
    <maxdate>
      <connection/>
      <table/>
      <field/>
      <offset>0.0</offset>
      <maxdiff>0.0</maxdiff>
    </maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <dependencies>
    </dependencies>
    <partitionschemas>
    </partitionschemas>
    <slaveservers>
    </slaveservers>
    <clusterschemas>
    </clusterschemas>
    <created_user>-</created_user>
    <created_date>2025/02/28 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2025/02/28 00:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <note>Workshop 5: Text Summarization

Summarize documents with structured output:
- Summary: 2-3 sentence overview
- Bullet Points: Key points from document
- Key Takeaways: Main insights
- Action Items: Tasks to be done (if applicable)

Educational transformation with detailed prompts.</note>
      <xloc>50</xloc>
      <yloc>50</yloc>
      <width>400</width>
      <heigth>250</heigth>
      <fontname>Sans</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>0</fontcolorred>
      <fontcolorgreen>0</fontcolorgreen>
      <fontcolorblue>0</fontcolorblue>
      <backgroundcolorred>255</backgroundcolorred>
      <backgroundcolorgreen>255</backgroundcolorgreen>
      <backgroundcolorblue>100</backgroundcolorblue>
      <bordercolorred>200</bordercolorred>
      <bordercolorgreen>200</bordercolorgreen>
      <bordercolorblue>0</bordercolorblue>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Read Documents</from>
      <to>Build Summarization Prompt</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Build Summarization Prompt</from>
      <to>Build JSON Request</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Build JSON Request</from>
      <to>Call Ollama API</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Call Ollama API</from>
      <to>Parse Summary Response</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parse Summary Response</from>
      <to>Write Summaries CSV</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>Read Documents</name>
    <type>CsvInput</type>
    <description>Read documents to summarize</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${Internal.Transformation.Filename.Directory}/../data/documents_to_summarize.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>Y</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>document_id</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>50</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>document_type</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>100</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>title</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>500</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>full_text</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>50000</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>100</xloc>
      <yloc>350</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Build Summarization Prompt</name>
    <type>ScriptValueMod</type>
    <description>Create summarization prompt for LLM</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Build text summarization prompt
var llm_prompt = "Summarize the following document and return ONLY a valid JSON object with this structure:\n\n" +
  "{\n" +
  "  \"summary\": \"2-3 sentence overview of the document\",\n" +
  "  \"bullet_points\": [\"key point 1\", \"key point 2\", \"key point 3\"],\n" +
  "  \"key_takeaways\": [\"main insight 1\", \"main insight 2\", \"main insight 3\"],\n" +
  "  \"action_items\": [\"action 1\", \"action 2\"] or [] if none\n" +
  "}\n\n" +
  "Instructions:\n" +
  "- Summary: Provide a concise 2-3 sentence overview capturing the main topic and purpose\n" +
  "- Bullet Points: Extract 3-5 most important facts or points from the document\n" +
  "- Key Takeaways: List 2-4 main insights, conclusions, or lessons from the content\n" +
  "- Action Items: Identify any tasks, decisions, or follow-up actions mentioned (use empty array [] if none)\n\n" +
  "Rules:\n" +
  "- Return ONLY valid JSON, no additional text or explanation\n" +
  "- Be concise but accurate\n" +
  "- Focus on what matters most\n" +
  "- Use clear, professional language\n\n" +
  "DOCUMENT TYPE: " + document_type + "\n" +
  "TITLE: " + title + "\n\n" +
  "DOCUMENT TEXT:\n" +
  full_text;</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>llm_prompt</name>
        <rename>llm_prompt</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>250</xloc>
      <yloc>350</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Build JSON Request</name>
    <type>ScriptValueMod</type>
    <description>Create Ollama API request</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Build JSON request body for Ollama API
var model_name = getVariable("MODEL_NAME", "llama3.2:3b");

var requestObj = {
    "model": model_name,
    "prompt": llm_prompt,
    "stream": false,
    "format": "json",
    "options": {
        "temperature": 0.2,
        "num_predict": 800
    }
};

var request_body = JSON.stringify(requestObj);
</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>request_body</name>
        <rename>request_body</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>400</xloc>
      <yloc>350</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Call Ollama API</name>
    <type>Rest</type>
    <description>Send summarization request to LLM</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <applicationType>TEXT PLAIN</applicationType>
    <method>POST</method>
    <url>${OLLAMA_URL}/api/generate</url>
    <urlInField>N</urlInField>
    <dynamicMethod>N</dynamicMethod>
    <methodFieldName/>
    <urlField/>
    <bodyField>request_body</bodyField>
    <httpLogin/>
    <httpPassword/>
    <proxyHost/>
    <proxyPort/>
    <preemptive>N</preemptive>
    <trustStoreFile/>
    <trustStorePassword/>
    <headers>
    </headers>
    <parameters>
    </parameters>
    <result>
      <name>api_response</name>
      <code>result_code</code>
      <response_time>response_time</response_time>
      <response_header/>
    </result>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>550</xloc>
      <yloc>350</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Parse Summary Response</name>
    <type>ScriptValueMod</type>
    <description>Extract summary components from JSON response</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Parse Ollama response and extract summary components
var summary = "";
var bullet_points = "[]";
var key_takeaways = "[]";
var action_items = "[]";

try {
    var response = JSON.parse(api_response);
    var fullResponse = response.response;

    // Extract JSON object from response
    var jsonStart = fullResponse.indexOf("{");
    var jsonEnd = fullResponse.lastIndexOf("}") + 1;

    if (jsonStart &gt;= 0 &amp;&amp; jsonEnd &gt; jsonStart) {
        var jsonStr = fullResponse.substring(jsonStart, jsonEnd);
        var summaryObj = JSON.parse(jsonStr);

        // Extract summary fields
        summary = summaryObj.summary || "";

        // Convert arrays to JSON strings
        if (summaryObj.bullet_points &amp;&amp; Array.isArray(summaryObj.bullet_points)) {
            bullet_points = JSON.stringify(summaryObj.bullet_points);
        }

        if (summaryObj.key_takeaways &amp;&amp; Array.isArray(summaryObj.key_takeaways)) {
            key_takeaways = JSON.stringify(summaryObj.key_takeaways);
        }

        if (summaryObj.action_items &amp;&amp; Array.isArray(summaryObj.action_items)) {
            action_items = JSON.stringify(summaryObj.action_items);
        }
    }
} catch(e) {
    summary = "Error parsing response: " + e.message;
    bullet_points = "[]";
    key_takeaways = "[]";
    action_items = "[]";
}
</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>summary</name>
        <rename>summary</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>bullet_points</name>
        <rename>bullet_points</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>key_takeaways</name>
        <rename>key_takeaways</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>action_items</name>
        <rename>action_items</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>700</xloc>
      <yloc>350</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Write Summaries CSV</name>
