<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>text_summarization_optimized</name>
    <description>Optimized Text Summarization with Parallel Processing</description>
    <extended_description>Optimized version with parallel API calls, compact prompts, and keep-alive for 3-4x performance improvement.

Key Features:
- Generates concise 2-3 sentence summaries
- Extracts bullet points, key takeaways, and action items
- Returns structured JSON output
- Parallel processing with configurable step copies
- Compact prompt (50% shorter than basic version)
- Keep-alive to maintain model in memory
- Handles diverse document types: meetings, reports, emails, etc.

Use Case: High-volume document processing, meeting notes summarization, content digestion</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>KEEP_ALIVE</name>
        <default_value>15m</default_value>
        <description>Keep model loaded in memory (5m/15m/30m/60m)</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>LLM model to use for summarization</description>
      </parameter>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434</default_value>
        <description>Ollama API base URL</description>
      </parameter>
      <parameter>
        <name>STEP_COPIES</name>
        <default_value>4</default_value>
        <description>Number of parallel API call copies (set to CPU cores - 1)</description>
      </parameter>
    </parameters>
