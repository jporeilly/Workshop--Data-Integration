<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>data_quality_enhancement_optimized</name>
    <description>Workshop 2: Data Quality Enhancement using Ollama LLM (Optimized)</description>
    <extended_description>OPTIMIZED version with parallel processing (4 copies), optimized prompts, and improved error handling. Processes customer data 3-4x faster than basic version.</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>INPUT_FILE</name>
        <default_value>${Internal.Transformation.Filename.Directory}/../data/customer_data_raw.csv</default_value>
        <description>Input CSV file with raw customer data</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>Ollama model to use (3b recommended for quality)</description>
      </parameter>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434</default_value>
        <description>Ollama API endpoint</description>
      </parameter>
      <parameter>
        <name>STEP_COPIES</name>
        <default_value>4</default_value>
        <description>Number of parallel API call copies (4-8 recommended)</description>
      </parameter>
    </parameters>
