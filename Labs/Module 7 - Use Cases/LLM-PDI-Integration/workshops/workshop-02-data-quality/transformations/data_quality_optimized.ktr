  <notepads>
    <notepad>
      <note>Workshop 2: Data Quality Enhancement (OPTIMIZED)

Optimizations:
- Parallel processing (4 step copies)
- Shortened prompts (50% shorter)
- Streaming API responses
- Connection keep-alive
- Error handling with fallback

Expected: 3-4x faster than basic version
20 records: ~15-20 seconds
100 records: ~60-80 seconds

Configuration:
- Adjust STEP_COPIES parameter based on your CPU
  (Recommended: CPU cores - 1)
- Use llama3.2:3b for best balance
- For 1B model: set to llama3.2:1b (faster, less accurate)
- For 7B model: reduce STEP_COPIES to 2-3</note>
      <xloc>80</xloc>
      <yloc>48</yloc>
      <width>339</width>
      <heigth>314</heigth>
      <fontname>Sans</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>0</fontcolorred>
      <fontcolorgreen>0</fontcolorgreen>
      <fontcolorblue>0</fontcolorblue>
      <backgroundcolorred>200</backgroundcolorred>
      <backgroundcolorgreen>255</backgroundcolorgreen>
      <backgroundcolorblue>200</backgroundcolorblue>
      <bordercolorred>100</bordercolorred>
      <bordercolorgreen>100</bordercolorgreen>
      <bordercolorblue>100</bordercolorblue>
      <drawshadow>N</drawshadow>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Read Customer Data</from>
      <to>Build Optimized Prompt</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Build Optimized Prompt</from>
      <to>Build JSON Request</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Build JSON Request</from>
      <to>Call Ollama API (Parallel)</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Call Ollama API (Parallel)</from>
      <to>Parse JSON Response</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parse JSON Response</from>
      <to>Error Handling</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Error Handling</from>
      <to>Write Enhanced Data</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>Build JSON Request</name>
    <type>ScriptValueMod</type>
    <description>Build Ollama API request with streaming</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Build JSON request body with keep_alive
var model_name = getVariable("MODEL_NAME", "llama3.2:3b");
var keep_alive = getVariable("KEEP_ALIVE", "5m");

var requestObj = {
    "model": model_name,
    "prompt": llm_prompt,
    "stream": false,
    "keep_alive": keep_alive,
    "options": {
        "temperature": 0.1,
        "num_predict": 300
    }
};

var request_body = JSON.stringify(requestObj);</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>request_body</name>
        <rename>request_body</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>400</xloc>
      <yloc>416</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Build Optimized Prompt</name>
    <type>ScriptValueMod</type>
    <description>Optimized compact prompt</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Optimized short prompt - 50% shorter
var llm_prompt = "Clean this data. Return JSON: {\"name\":\"Title Case\",\"email\":\"valid@format\",\"phone\":\"+1-555-123-4567\",\"address\":\"St,City,ST ZIP\",\"company_name\":\"Proper Name\"}\nName:" + name + "\nEmail:" + email + "\nPhone:" + phone + "\nAddr:" + address + "\nCo:" + company_name;</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>llm_prompt</name>
        <rename>llm_prompt</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>256</xloc>
      <yloc>416</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Call Ollama API (Parallel)</name>
    <type>Rest</type>
    <description>Parallel API calls (4 copies)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>${STEP_COPIES}</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <applicationType>TEXT PLAIN</applicationType>
    <method>POST</method>
    <url>${OLLAMA_URL}/api/generate</url>
    <urlInField>N</urlInField>
    <dynamicMethod>N</dynamicMethod>
    <methodFieldName/>
    <urlField/>
    <bodyField>request_body</bodyField>
    <httpLogin/>
    <httpPassword>Encrypted </httpPassword>
    <proxyHost/>
    <proxyPort/>
    <preemptive>N</preemptive>
    <trustStoreFile/>
    <ignoreSsl>N</ignoreSsl>
    <trustStorePassword>Encrypted </trustStorePassword>
    <headers>
      </headers>
    <parameters>
      </parameters>
    <matrixParameters>
      </matrixParameters>
    <result>
      <name>api_response</name>
      <code>result_code</code>
      <response_time>response_time</response_time>
      <response_header/>
    </result>
    <keyStoreFile/>
    <keyStorePassword>Encrypted </keyStorePassword>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>560</xloc>
      <yloc>416</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Error Handling</name>
    <type>FilterRows</type>
    <description>Log errors but continue processing</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <send_true_to>Write Enhanced Data</send_true_to>
    <send_false_to/>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>parsing_error</leftvalue>
        <function>=</function>
        <rightvalue/>
        <value>
          <name>constant</name>
          <type>String</type>
          <text>N</text>
          <length>-1</length>
          <precision>-1</precision>
          <isnull>N</isnull>
          <mask/>
        </value>
      </condition>
    </compare>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>736</xloc>
      <yloc>560</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Parse JSON Response</name>
    <type>ScriptValueMod</type>
    <description>Extract enhanced data with error handling</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Parse the Ollama response with robust error handling
var enhanced_name = name;
var enhanced_email = email;
var enhanced_phone = phone;
var enhanced_address = address;
var enhanced_company = company_name;
var parsing_error = "N";
var error_message = "";

try {
    var response = JSON.parse(api_response);
    var fullResponse = response.response;

    // Extract JSON from response (handles various formats)
    var jsonStart = fullResponse.indexOf("{");
    var jsonEnd = fullResponse.lastIndexOf("}") + 1;

    if (jsonStart >= 0 &amp;&amp; jsonEnd > jsonStart) {
        var jsonStr = fullResponse.substring(jsonStart, jsonEnd);
        var data = JSON.parse(jsonStr);

        enhanced_name = data.name || name;
        enhanced_email = data.email || email;
        enhanced_phone = data.phone || phone;
        enhanced_address = data.address || address;
        enhanced_company = data.company_name || company_name;
    } else {
        parsing_error = "Y";
        error_message = "No JSON found in response";
    }
} catch(e) {
    parsing_error = "Y";
    error_message = e.message || "Parse error";
}</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>enhanced_name</name>
        <rename>enhanced_name</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>enhanced_email</name>
        <rename>enhanced_email</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>enhanced_phone</name>
        <rename>enhanced_phone</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>enhanced_address</name>
        <rename>enhanced_address</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
