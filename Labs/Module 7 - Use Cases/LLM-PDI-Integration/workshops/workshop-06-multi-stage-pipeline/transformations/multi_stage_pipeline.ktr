<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>multi_stage_pipeline</name>
    <description>Multi-Stage LLM Pipeline - Intelligent Document Router with 5 sequential AI stages</description>
    <extended_description>This transformation demonstrates advanced LLM orchestration with chained AI calls:

Stage 1: Document Classification (type identification)
Stage 2: Urgency &amp; Priority Scoring (1-10 urgency score)
Stage 3: Type-Specific Information Extraction (conditional based on type)
Stage 4: Action Item Generation (specific tasks to complete)
Stage 5: Department Routing (who should handle this)

Each stage builds on previous stage outputs, creating an intelligent processing pipeline.

Use Case: Automated document triage and routing system for support, security, legal, etc.</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>LLM model to use for all stages</description>
      </parameter>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434</default_value>
        <description>Ollama API base URL</description>
      </parameter>
    </parameters>
