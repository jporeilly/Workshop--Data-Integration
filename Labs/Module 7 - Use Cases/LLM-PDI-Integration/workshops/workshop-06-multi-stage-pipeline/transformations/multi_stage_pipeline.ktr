    <name>Stage 3: Build Extraction Prompt</name>
    <type>ScriptValueMod</type>
    <description>Conditional extraction based on doc_type from Stage 1</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
