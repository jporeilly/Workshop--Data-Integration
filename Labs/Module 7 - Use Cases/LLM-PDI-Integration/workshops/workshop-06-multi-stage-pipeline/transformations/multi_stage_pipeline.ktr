  <step>
    <name>Stage 5: Build Routing Prompt</name>
    <type>ScriptValueMod</type>
    <description>Determine department routing based on all previous stages</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
