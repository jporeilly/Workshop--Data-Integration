        <name>INPUT_FILE</name>
        <default_value>${Internal.Transformation.Filename.Directory}/../data/customer_reviews.csv</default_value>
        <description>Input CSV file path</description>
      </parameter>
      <parameter>
        <name>KEEP_ALIVE</name>
        <default_value>30m</default_value>
        <description>Keep model in memory (5m/15m/30m/60m)</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>Ollama model (3b recommended for Intel CPU)</description>
      </parameter>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434</default_value>
        <description>Ollama API endpoint</description>
      </parameter>
      <parameter>
        <name>STEP_COPIES</name>
        <default_value>4</default_value>
        <description>Parallel copies (set to CPU cores - 1)</description>
      </parameter>
    </parameters>
