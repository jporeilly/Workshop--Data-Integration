    <fields>
      <field>
        <name>sentiment</name>
        <path>$.sentiment</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>score</name>
        <path>$.score</path>
        <type>Number</type>
        <format>#.##</format>
        <currency/>
