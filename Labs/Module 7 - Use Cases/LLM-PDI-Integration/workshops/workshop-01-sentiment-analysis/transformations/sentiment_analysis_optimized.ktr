<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>sentiment_analysis_optimized</name>
    <description>OPTIMIZED Workshop 1: High-Performance Sentiment Analysis (Intel CPU Tuned)</description>
    <extended_description>This optimized transformation uses parallel processing, optimized prompts, and Intel CPU-specific configurations for maximum performance. Expected: 3-4x faster than basic version.</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <trans_status>0</trans_status>
    <directory>/</directory>
    <parameters>
