<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>sentiment_analysis</name>
    <description>Workshop 1: Customer Review Sentiment Analysis using Ollama LLM</description>
    <extended_description>This transformation reads customer reviews, sends them to Ollama for sentiment analysis, and stores the results with sentiment scores and categories.</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>INPUT_FILE</name>
        <default_value>${Internal.Transformation.Filename.Directory}/../data/customer_reviews.csv</default_value>
        <description>Input CSV file path</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>Ollama model to use</description>
      </parameter>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434</default_value>
        <description>Ollama API endpoint</description>
      </parameter>
    </parameters>
