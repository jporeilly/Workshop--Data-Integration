<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>data_enrichment_optimized</name>
    <description>Workshop 3: Optimized Data Enrichment with Parallel Processing</description>
    <extended_description>Optimized version with parallel API calls, compact prompts, and keep-alive for 3-4x performance improvement</extended_description>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <trans_status>0</trans_status>
    <directory>/</directory>
    <parameters>
      <parameter>
        <name>INPUT_FILE</name>
        <default_value>/home/pentaho/LLM-PDI-Integration/workshops/workshop-03-data-enrichment/data/customer_data_incomplete.csv</default_value>
        <description>Path to input CSV file with incomplete data</description>
      </parameter>
      <parameter>
        <name>KEEP_ALIVE</name>
        <default_value>15m</default_value>
        <description>Keep model loaded in memory (5m/15m/30m/60m)</description>
      </parameter>
      <parameter>
        <name>MODEL_NAME</name>
        <default_value>llama3.2:3b</default_value>
        <description>Ollama model to use for enrichment</description>
      </parameter>
      <parameter>
        <name>OLLAMA_URL</name>
        <default_value>http://localhost:11434</default_value>
        <description>Ollama API endpoint URL</description>
      </parameter>
      <parameter>
        <name>STEP_COPIES</name>
        <default_value>4</default_value>
        <description>Number of parallel API call copies (set to CPU cores - 1)</description>
      </parameter>
    </parameters>
